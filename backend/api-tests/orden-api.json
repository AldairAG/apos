  "ejemploFlujoCompleto": {
    "name": "Flujo Completo: Crear una Orden con Productos y Extras",
    "steps": [
      {
        "step": 1,
        "description": "Crear la orden",
        "method": "POST",
        "endpoint": "/ordenes",
        "body": {
          "tipo": "COMER_AQUI",
          "numeroPersonas": 2,
          "nombreCliente": "María López",
          "sucursal": {
            "id": 1
          },
          "mesa": {
            "id": 5
          },
          "empleado": {
            "id": 1
          }
        },
        "response": {
          "id": 1,
          "folio": "SUC1-20260616-00001"
        }
      },
      {
        "step": 2,
        "description": "Agregar producto 1 (Cappuccino)",
        "method": "POST",
        "endpoint": "/detalles-orden",
        "body": {
          "orden": {
            "id": 1
          },
          "producto": {
            "id": 1
          },
          "cantidad": 2,
          "precioUnitario": 45.00
        },
        "response": {
          "id": 101
        }
      },
      {
        "step": 3,
        "description": "Agregar extra (tamaño grande) al cappuccino",
        "method": "POST",
        "endpoint": "/detalles-orden/101/extras",
        "queryParams": {
          "idOpcionExtra": 3
        }
      },
      {
        "step": 4,
        "description": "Agregar producto 2 (Sandwich)",
        "method": "POST",
        "endpoint": "/detalles-orden",
        "body": {
          "orden": {
            "id": 1
          },
          "producto": {
            "id": 5
          },
          "cantidad": 1,
          "precioUnitario": 65.00
        }
      },
      {
        "step": 5,
        "description": "Aplicar descuento del 10%",
        "method": "PUT",
        "endpoint": "/ordenes/1/descuento",
        "queryParams": {
          "descuento": 10.00
        }
      },
      {
        "step": 6,
        "description": "Recalcular totales",
        "method": "PUT",
        "endpoint": "/ordenes/1/calcular-totales"
      },
      {
        "step": 7,
        "description": "Cambiar estado a EN_PREPARACION",
        "method": "PUT",
        "endpoint": "/ordenes/1/estado",
        "queryParams": {
          "estado": "EN_PREPARACION",
          "idEmpleado": 1
        }
      },
      {
        "step": 8,
        "description": "Cerrar orden (marcar como LISTA)",
        "method": "PUT",
        "endpoint": "/ordenes/1/cerrar"
      },
      {
        "step": 9,
        "description": "Completar orden (ENTREGADA)",
        "method": "PUT",
        "endpoint": "/ordenes/1/completar",
        "queryParams": {
          "idEmpleado": 1
        }
      }
    ]
  }
}
